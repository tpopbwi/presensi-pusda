<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Admin Panel - UPT PUSDA</title>
    
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#0d1b3e">
    
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&family=JetBrains+Mono:wght@500;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #1e40af; --bg-dark: #0d1b3e; --glass: rgba(15, 32, 77, 0.85); 
            --glass-border: rgba(255, 255, 255, 0.12); --accent: #f97316;
            --success: #10b981; --danger: #ef4444; --warning: #facc15;
            --pu-blue: #3b82f6; --sda-toska: #2dd4bf; --sidebar-width: 280px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; -webkit-tap-highlight-color: transparent; }
        html, body { width: 100%; min-height: 100vh; background: var(--bg-dark); color: #f8fafc; overflow-x: hidden; scroll-behavior: smooth; }
        body { display: flex; position: relative; width: 100vw; }
        
        .fixed-bg { position: fixed; inset: 0; z-index: -1; background: radial-gradient(circle at top right, #1e40af, #0d1b3e 85%), radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.3), transparent 70%); }

        /* --- SIDEBAR --- */
        .sidebar { width: var(--sidebar-width); height: calc(100vh - 40px); position: fixed; top: 20px; left: 20px; background: rgba(15, 32, 77, 0.96); backdrop-filter: blur(25px); border: 1px solid var(--glass-border); border-radius: 24px; padding: 25px; display: flex; flex-direction: column; z-index: 1000; box-shadow: 0 20px 50px rgba(0,0,0,0.3); }
        .brand { display: flex; align-items: center; gap: 12px; margin-bottom: 35px; padding-bottom: 20px; border-bottom: 1px solid var(--glass-border); }
        .brand img { height: 42px; border-radius: 8px; }
        .nav-link { padding: 14px 18px; border-radius: 16px; display: flex; align-items: center; gap: 14px; color: rgba(255,255,255,0.6); text-decoration: none; transition: 0.3s; font-weight: 600; margin-bottom: 5px; cursor: pointer; }
        .nav-link:hover { background: rgba(255,255,255,0.05); color: white; transform: translateX(5px); }
        .nav-link.active { background: linear-gradient(135deg, var(--pu-blue), var(--primary)); color: white; box-shadow: 0 10px 20px rgba(30, 64, 175, 0.4); }

        .sidebar-clock { margin-top: auto; padding: 20px; background: rgba(0,0,0,0.3); border: 1px solid var(--glass-border); border-radius: 22px; text-align: center; backdrop-filter: blur(10px); }
        .sidebar-clock p { font-size: 0.6rem; font-weight: 800; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 5px; }
        .sidebar-clock h2 { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; color: var(--sda-toska); font-weight: 800; }

        /* --- MAIN CONTENT (FULL WIDE) --- */
        .main-content { flex: 1; margin-left: calc(var(--sidebar-width) + 30px); padding: 30px; min-height: 100vh; display: none; flex-direction: column; width: calc(100% - var(--sidebar-width) - 30px); }
        .dashboard-container { width: 100%; display: flex; flex-direction: column; gap: 25px; }

        /* --- CARD & TABLE --- */
        .admin-card { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 35px; padding: 25px; display: flex; flex-direction: column; gap: 20px; backdrop-filter: blur(35px); box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
        .table-scroll { width: 100%; overflow-x: auto; border-radius: 20px; border: 1px solid var(--glass-border); background: rgba(0,0,0,0.25); }
        table { width: 100%; border-collapse: collapse; min-width: 1000px; }
        th { background: rgba(255,255,255,0.06); text-align: left; padding: 18px 20px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; color: var(--sda-toska); letter-spacing: 1px; }
        td { padding: 15px 20px; border-bottom: 1px solid var(--glass-border); font-size: 0.9rem; color: white; vertical-align: middle; }

        .foto-pegawai-sm { width: 45px; height: 65px; border-radius: 10px; border: 1.5px solid var(--glass-border); background: transparent; overflow: hidden; display: flex; align-items: center; justify-content: center; }
        .foto-pegawai-sm img { width: 100%; height: 100%; object-fit: contain; }
        .qr-thumb-sm { width: 42px; height: 42px; border-radius: 8px; background: white; padding: 2px; cursor: pointer; }

        .action-cell { display: flex; gap: 8px; }
        .action-icon { width: 38px; height: 38px; border-radius: 12px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.05); color: white; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: 0.2s; }
        .action-icon:hover { background: var(--primary); transform: scale(1.1); }
        .action-icon.delete:hover { background: var(--danger); }

        /* --- LOGIN SCREEN --- */
        #loginOverlay { position: fixed; inset: 0; z-index: 10000; background: radial-gradient(circle at center, #1e40af, #0d1b3e 100%); display: flex; align-items: center; justify-content: center; padding: 20px; }
        .login-card { background: var(--glass); border: 1px solid var(--glass-border); border-radius: 40px; padding: 45px 35px; width: 100%; max-width: 400px; text-align: center; backdrop-filter: blur(40px); box-shadow: 0 40px 100px rgba(0,0,0,0.7); }
        .login-input { margin-bottom: 25px; text-align: center; font-size: 1.2rem; letter-spacing: 6px; }
        
        .login-brand-img { height: 45px; margin-top: 30px; opacity: 0.8; filter: drop-shadow(0 0 10px rgba(255,255,255,0.2)); }
        .version-text { font-size: 0.6rem; font-weight: 900; opacity: 0.4; letter-spacing: 3px; text-transform: uppercase; margin: 10px 0 20px 0; color: white; }
        
        .google-play-btn { 
            display: inline-flex; align-items: center; gap: 12px; background: #000; padding: 12px 20px; 
            border-radius: 15px; border: 1px solid rgba(255,255,255,0.2); text-decoration: none; color: white; 
            transition: 0.3s;
        }

        #sendingOverlay { position: fixed; inset: 0; z-index: 60000; background: rgba(13, 27, 62, 0.95); display: none; flex-direction: column; align-items: center; justify-content: center; color: white; backdrop-filter: blur(10px); }

        /* --- MODAL (MINIM PADING) --- */
        .modal { display: none; position: fixed; inset: 0; z-index: 5000; background: rgba(13, 27, 62, 0.98); backdrop-filter: blur(20px); justify-content: center; align-items: center; padding: 10px; }
        .modal-content { max-width: 780px; width: 100%; background: #0b1120; border-radius: 40px; border: 1px solid var(--glass-border); padding: 25px; position: relative; max-height: 98vh; overflow-y: auto; box-shadow: 0 50px 100px rgba(0,0,0,0.8); }
        .modal-body-p { display: grid; grid-template-columns: 220px 1fr; gap: 20px; }
        .p-preview-frame { width: 100%; aspect-ratio: 2/3; border-radius: 25px; border: 2px dashed var(--glass-border); background: rgba(255,255,255,0.02); display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; overflow: hidden; position: relative; }
        .p-preview-frame img { width: 100%; height: 100%; object-fit: contain; z-index: 2; position: absolute; }
        .qr-preview-box { margin-top: 15px; background: white; padding: 12px; border-radius: 20px; text-align: center; }
        .qr-preview-box img { width: 130px; height: 130px; }

        input, select, textarea { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); padding: 14px 18px; border-radius: 15px; color: white; outline: none; font-weight: 600; font-size: 0.9rem; }
        label { font-size: 0.6rem; font-weight: 800; color: var(--sda-toska); text-transform: uppercase; margin-left: 10px; margin-bottom: 4px; display: block; letter-spacing: 1px; }

        .btn-premium { width: 100%; padding: 18px; border-radius: 20px; border: none; background: linear-gradient(135deg, var(--pu-blue), var(--primary)); color: white; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 10px 25px rgba(30, 64, 175, 0.4); text-transform: uppercase; letter-spacing: 1px; }

        /* --- MOBILE NAVIGATION --- */
        .bottom-nav-admin { 
            display: none; 
            grid-template-columns: repeat(5, 1fr); 
            position: fixed; bottom: 15px; left: 10px; right: 10px; 
            height: 70px; background: #0f172a; border-radius: 35px; 
            z-index: 1000; align-items: center; border: 1px solid var(--glass-border); 
            backdrop-filter: blur(25px); box-shadow: 0 25px 50px rgba(0,0,0,0.8);
        }
        .b-nav-item { display: flex; flex-direction: column; align-items: center; gap: 4px; color: rgba(255,255,255,0.3); text-decoration: none; font-size: 0.55rem; font-weight: 800; width: 100%; cursor: pointer; text-transform: uppercase; }
        .b-nav-item.active { color: var(--sda-toska); }

        @media (max-width: 768px) {
            .sidebar { display: none; }
            .main-content { margin-left: 0; padding: 10px 10px 130px 10px; width: 100%; }
            .bottom-nav-admin { display: grid; }
            .modal-content { padding: 18px; border-radius: 30px; }
            .modal-body-p { grid-template-columns: 1fr; gap: 12px; }
            .p-preview-frame { max-width: 170px; margin: 0 auto; }
            .admin-card { padding: 15px; border-radius: 25px; gap: 15px; }
        }

        @media (max-width: 400px) {
            .main-content { padding: 6px 6px 120px 6px; }
            .admin-card { padding: 12px; border-radius: 20px; }
            td, th { padding: 10px 8px; font-size: 0.7rem; }
            .action-icon { width: 32px; height: 32px; border-radius: 10px; }
        }
    </style>
</head>
<body>

    <div class="fixed-bg"></div>
    <div id="sendingOverlay">
        <div style="width:50px;height:50px;border:5px solid rgba(255,255,255,0.1);border-top-color:var(--sda-toska);border-radius:50%;animation:spin 1s infinite linear;"></div>
        <p id="overlayText" style="margin-top:20px; font-weight:800; text-transform:uppercase; letter-spacing:3px;">Sinkronisasi...</p>
    </div>

    <!-- LOGIN SCREEN -->
    <div id="loginOverlay">
        <div class="login-card">
            <div style="background:var(--primary);width:65px;height:65px;border-radius:22px;margin:0 auto 20px;display:flex;align-items:center;justify-content:center;"><i data-lucide="shield-check" color="white" size="36"></i></div>
            <h1 style="font-weight:800; margin-bottom:10px;">Admin Panel</h1>
            <p style="opacity:0.5; margin-bottom:30px; font-size:0.9rem;">Sistem Informasi Manajemen Terpadu</p>
            
            <input type="password" id="adminPass" class="login-input" placeholder="••••••••">
            <button class="btn-premium" onclick="attemptLogin()">Otentikasi Masuk</button>
            
            <img src="" id="loginBrandLogo" class="login-brand-img">
            <p class="version-text">VERSION 4.8.5 - 2026</p>
            
            <a href="#" id="playStoreLink" target="_blank" class="google-play-btn">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3.56 3.37c-.22.16-.34.42-.34.72v15.82c0 .3.12.56.34.72l8.75-8.63-8.75-8.63z" fill="#EA4335"/><path d="M16.44 7.81L3.56 3.37c-.22-.08-.34.02-.34.18v.55L16.44 7.81z" fill="#FBBC04"/><path d="M3.22 19.91v.18c0 .16.12.26.34.18l12.88-4.44-13.22 4.08z" fill="#34A853"/><path d="M16.44 16.19l3.72-2.07c.9-.5 1.05-1.75.15-2.25l-3.87-2.06-4.13 2.19 4.13 2.19z" fill="#4285F4"/>
                </svg>
                <div style="text-align:left; line-height:1;"><span style="font-size:0.55rem; font-weight:600; opacity:0.7;">GET IT ON</span><br><span style="font-size:0.95rem; font-weight:800;">Google Play</span></div>
            </a>
        </div>
    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="brand"><img src="" id="sidebarLogo"><div><h1 style="font-weight: 800; font-size: 1.1rem;"><span style="color:var(--pu-blue)">PU</span> <span style="color:var(--sda-toska)">SDA</span></h1><p style="font-size: 0.55rem; opacity: 0.6; font-weight: 800;">WS BONDOYUDO BARU</p></div></div>
        <nav id="sidebarNav">
            <div class="nav-link active" onclick="switchTab('pegawai')"><i data-lucide="users"></i> Data Pegawai</div>
            <div class="nav-link" onclick="switchTab('korlap')"><i data-lucide="award"></i> Data Korlap</div>
            <div class="nav-link" onclick="switchTab('logs')"><i data-lucide="history"></i> Log Presensi</div>
            <div class="nav-link" onclick="switchTab('tools')"><i data-lucide="layout-grid"></i> Layanan</div>
            <div class="nav-link" onclick="switchTab('config')"><i data-lucide="settings"></i> Pengaturan</div>
            <a href="index.html" class="nav-link" style="margin-top: 30px; border-top: 1px solid var(--glass-border); padding-top: 20px; opacity: 0.5;"><i data-lucide="home"></i> Dashboard Utama</a>
        </nav>
        <div class="sidebar-clock"><p>WAKTU SERVER</p><h2 id="liveClock">00:00</h2></div>
    </aside>

    <main class="main-content" id="mainContent">
        <div class="dashboard-container">
            <!-- TAB DATA PEGAWAI -->
            <section id="tab-pegawai" class="admin-tab">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
                    <h1 style="font-size:1.5rem; font-weight:800;">Data Pegawai</h1>
                    <button class="btn-premium" style="width:auto;padding:10px 20px;border-radius:12px;" onclick="openPModal('pegawai')"><i data-lucide="plus"></i> TAMBAH</button>
                </div>
                <div class="admin-card">
                    <div class="table-scroll"><table><thead><tr><th>ID</th><th>QR</th><th>Profil</th><th>Nama Lengkap</th><th>Jabatan</th><th>Wilayah WS</th><th>Status</th><th>Aksi</th></tr></thead><tbody id="pegawaiBody"></tbody></table></div>
                </div>
            </section>

            <!-- TAB DATA KORLAP -->
            <section id="tab-korlap" class="admin-tab" style="display:none;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
                    <h1 style="font-size:1.5rem; font-weight:800;">Data Korlap</h1>
                    <button class="btn-premium" style="width:auto;padding:10px 20px;border-radius:12px;" onclick="openPModal('korlap')"><i data-lucide="plus"></i> TAMBAH</button>
                </div>
                <div class="admin-card">
                    <div class="table-scroll"><table><thead><tr><th>ID</th><th>QR</th><th>Profil</th><th>Nama Korlap</th><th>Jabatan</th><th>Wilayah Kerja</th><th>Status</th><th>Aksi</th></tr></thead><tbody id="korlapBody"></tbody></table></div>
                </div>
            </section>

            <!-- TAB LOG PRESENSI -->
            <section id="tab-logs" class="admin-tab" style="display:none;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
                    <h1 style="font-size:1.5rem; font-weight:800;">Log Presensi</h1>
                    <div style="display:flex; gap:8px;"><input type="date" id="logDateFilter" onchange="loadLogs()" style="width:auto;"><button class="btn-premium" style="width:auto; padding:10px 15px; background:var(--success);" onclick="openLogModal('add')"><i data-lucide="plus"></i></button></div>
                </div>
                <div class="admin-card"><div class="table-scroll"><table><thead><tr><th>Waktu</th><th>Nama Personel</th><th>Status</th><th>Skor</th><th>Wilayah</th><th>Bukti</th><th>Opsi</th></tr></thead><tbody id="logsBody"></tbody></table></div></div>
            </section>

            <!-- TAB LAYANAN -->
            <section id="tab-tools" class="admin-tab" style="display:none;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
                    <h1 style="font-size:1.5rem; font-weight:800;">Layanan Digital</h1>
                    <button class="btn-premium" style="width:auto;padding:10px 20px;" onclick="openToolModal()"><i data-lucide="plus"></i> TAMBAH</button>
                </div>
                <div class="admin-card">
                    <div class="table-scroll"><table><thead><tr><th>Icon</th><th>Nama Layanan</th><th>Deskripsi Singkat</th><th>Aksen</th><th>Aksi</th></tr></thead><tbody id="toolsBody"></tbody></table></div>
                </div>
            </section>

            <!-- TAB CONFIG -->
            <section id="tab-config" class="admin-tab" style="display:none;">
                <h1 style="font-size:1.5rem; font-weight:800; margin-bottom:20px;">Pengaturan Panel</h1>
                <div class="admin-card">
                    <div id="configContainer" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap:15px;"></div>
                    <button class="btn-premium" style="max-width:250px; margin-top:10px;" onclick="saveConfig()"><i data-lucide="save"></i> SIMPAN</button>
                </div>
            </section>
        </div>
    </main>

    <!-- MOBILE NAVIGATION -->
    <nav class="bottom-nav-admin" id="mobileNav">
        <div class="b-nav-item active" onclick="switchTab('pegawai')"><i data-lucide="users" size="20"></i><span>Pegawai</span></div>
        <div class="b-nav-item" onclick="switchTab('korlap')"><i data-lucide="award" size="20"></i><span>Korlap</span></div>
        <div class="b-nav-item" onclick="switchTab('logs')"><i data-lucide="history" size="20"></i><span>Logs</span></div>
        <div class="b-nav-item" onclick="switchTab('tools')"><i data-lucide="layout-grid" size="20"></i><span>Tools</span></div>
        <div class="b-nav-item" onclick="switchTab('config')"><i data-lucide="settings" size="20"></i><span>Config</span></div>
    </nav>

    <!-- MODAL PEGAWAI / KORLAP (Standardized) -->
    <div id="pModal" class="modal">
        <div class="modal-content">
            <h2 id="pModalTitle" style="margin-bottom:20px; border-left:5px solid var(--sda-toska); padding-left:15px; font-weight:800;">Informasi Personel</h2>
            <div class="modal-body-p">
                <div style="text-align:center;">
                    <div class="p-preview-frame" onclick="document.getElementById('p-file').click()"><img id="p-preview-img" style="display:none;"><div id="p-placeholder"><i data-lucide="camera" size="32"></i><p style="font-size:0.6rem; font-weight:800; margin-top:10px;">FOTO</p></div></div>
                    <input type="file" id="p-file" hidden accept="image/*" onchange="handleFile(this)">
                    <div id="qr-display-container" style="display:none;"><div class="qr-preview-box"><img id="p-qr-img" src=""><p id="qr-text-info" style="font-size:0.5rem; font-weight:800; margin-top:5px; color:#000;">QR AUTOMATIC</p></div></div>
                </div>
                <div style="display:grid; gap:12px;">
                    <input type="hidden" id="p-mode"><input type="hidden" id="p-old-id">
                    <div><label>ID Unik</label><input type="text" id="p-id"></div>
                    <div><label>Nama Lengkap</label><input type="text" id="p-nama" oninput="updateQRRealtime()"></div>
                    <div><label>Jabatan</label><input type="text" id="p-jabatan"></div>
                    <div><label>Wilayah Kerja</label><input type="text" id="p-wilayah"></div>
                    <div><label>WhatsApp (08...)</label><input type="text" id="p-nohp" oninput="updateQRRealtime()"></div>
                    <div><label>Lokasi Kerja Detail</label><input type="text" id="p-lokasi"></div>
                    <div><label>Status Akun</label><select id="p-status"><option value="Aktif">Aktif</option><option value="Non-Aktif">Non-Aktif</option></select></div>
                </div>
            </div>
            <button class="btn-premium" style="margin-top:25px;" onclick="savePAction()">SIMPAN DATA</button>
            <button style="width:100%; background:none; border:none; color:white; opacity:0.3; margin-top:10px; cursor:pointer; font-weight:800;" onclick="closeModal('pModal')">BATAL</button>
        </div>
    </div>

    <!-- MODAL LOG (Edit Dropdown) -->
    <div id="logEditModal" class="modal">
        <div class="modal-content" style="max-width:500px;">
            <h2 id="logModalTitle" style="margin-bottom:20px; border-left:5px solid var(--warning); padding-left:15px; font-weight:800;">Manajemen Log</h2>
            <div id="pegawaiSelectContainer"><label>Pilih Personel (Otomatis Terpilih)</label><select id="manualLogPegawai"></select></div>
            <input type="hidden" id="editLogOriginalTs"><input type="hidden" id="editLogIdPeg">
            <div style="display:grid; gap:12px; margin-top:15px;">
                <div><label>Waktu Presensi</label><input type="datetime-local" id="editLogTime"></div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <div><label>Status</label><select id="editLogStatus"><option value="Hadir">Hadir</option><option value="Terlambat">Terlambat</option><option value="Pulang">Pulang</option><option value="Izin">Izin</option><option value="Sakit">Sakit</option><option value="Dinas">Dinas</option></select></div>
                    <div><label>Skor</label><input type="number" id="editLogNilai"></div>
                </div>
            </div>
            <button class="btn-premium" style="margin-top:25px; background:linear-gradient(135deg, var(--warning), var(--accent));" onclick="saveLogAction()">SINKRONISASI LOG</button>
            <button style="width:100%; background:none; border:none; color:white; opacity:0.3; margin-top:10px; cursor:pointer;" onclick="closeModal('logEditModal')">BATAL</button>
        </div>
    </div>

    <!-- MODAL LAYANAN -->
    <div id="toolModal" class="modal">
        <div class="modal-content" style="max-width:500px;">
            <h2 style="margin-bottom:20px; border-left:5px solid var(--pu-blue); padding-left:15px;">Atur Layanan</h2>
            <div style="display:grid; gap:12px;">
                <input type="hidden" id="t-old-name">
                <div><label>Nama Layanan</label><input type="text" id="t-nama"></div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
                    <div><label>Ikon (Lucide)</label><input type="text" id="t-ikon"></div>
                    <div><label>Aksen</label><input type="color" id="t-warna" style="height:50px; padding:5px;"></div>
                </div>
                <div><label>URL</label><input type="text" id="t-url"></div>
                <div><label>Keterangan</label><textarea id="t-desc" rows="2"></textarea></div>
            </div>
            <button class="btn-premium" style="margin-top:25px;" onclick="saveTool()">SIMPAN LAYANAN</button>
            <button style="width:100%; background:none; border:none; color:white; opacity:0.3; margin-top:10px; cursor:pointer;" onclick="closeModal('toolModal')">BATAL</button>
        </div>
    </div>

    <script>
        const API = "https://script.google.com/macros/s/AKfycbzQIExXFgyE2tJM5si70CaLGBYWRvYBdqI9DJeF-GXzSoZiuw3ASs7tmGx7_TzHMUMy/exec";
        const placeholderImg = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 85'%3E%3Crect width='60' height='85' fill='%232e446e'/%3E%3Cpath d='M30 40c5.5 0 10-4.5 10-10s-4.5-10-10-10-10 4.5-10 10 4.5 10 10 10zm0 5c-8 0-20 4-20 12v5h40v-5c0-8-12-12-20-12z' fill='%23ffffff' opacity='0.2'/%3E%3C/svg%3E";
        let token = "", masterData = {}, base64Foto = null, logMode = 'edit';

        window.onload = () => { 
            lucide.createIcons(); 
            setInterval(() => { const el = document.getElementById('liveClock'); if(el) el.innerText = new Date().toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'}); }, 1000); 
            fetchInitial(); 
        };
        
        async function fetchInitial() { 
            try { 
                const r = await fetch(API + "?action=getDashboardData", { redirect: 'follow' }); 
                masterData = await r.json(); 
                if(masterData.config) {
                    if(masterData.config.Logo) {
                        document.getElementById('sidebarLogo').src = masterData.config.Logo; 
                        document.getElementById('loginBrandLogo').src = masterData.config.Logo; 
                    }
                    if(masterData.config.PlayStore_URL) document.getElementById('playStoreLink').href = masterData.config.PlayStore_URL;
                }
            } catch(e) {} 
        }

        async function attemptLogin() { 
            setLoading(true, "Otentikasi..."); 
            const r = await fetch(API, { method: 'POST', body: JSON.stringify({ action: 'loginAdmin', password: document.getElementById('adminPass').value }) }); 
            const d = await r.json(); 
            if (d.status === 'success') { 
                token = d.token; 
                document.getElementById('loginOverlay').style.display = 'none'; 
                document.getElementById('mainContent').style.display = 'flex'; 
                loadDashboard(); 
            } else alert("Sandi Salah"); 
            setLoading(false); 
        }

        async function loadDashboard() { 
            setLoading(true, "Sinkronisasi..."); 
            const r = await fetch(API + "?action=getDashboardData", { redirect: 'follow' }); 
            masterData = await r.json(); 
            renderPegawai(); renderKorlap(); renderTools(); renderConfig(); 
            setLoading(false); 
        }

        function switchTab(tab) { 
            document.querySelectorAll('.admin-tab').forEach(t => t.style.display='none'); 
            document.getElementById('tab-'+tab).style.display='block'; 
            document.querySelectorAll('.nav-link, .b-nav-item').forEach(l => l.classList.remove('active'));
            const selector = `.nav-link[onclick*="${tab}"], .b-nav-item[onclick*="${tab}"]`;
            document.querySelectorAll(selector).forEach(el => el.classList.add('active'));
            if(tab==='logs') loadLogs(); 
            lucide.createIcons(); 
        }

        function getQRUrl(nama, hp) { return `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent((nama || "NAMA") + "_" + (hp || "NOHP"))}`; }

        function updateQRRealtime() {
            const nama = document.getElementById('p-nama').value.trim();
            const hp = document.getElementById('p-nohp').value.trim();
            const qrImg = document.getElementById('p-qr-img');
            const qrContainer = document.getElementById('qr-display-container');
            if(nama || hp) { qrImg.src = getQRUrl(nama, hp); qrContainer.style.display = 'block'; } else { qrContainer.style.display = 'none'; }
        }

        function renderPegawai() { renderPersonelList(masterData.pegawai, 'pegawaiBody', 'pegawai'); }
        function renderKorlap() { renderPersonelList(masterData.korlap, 'korlapBody', 'korlap'); }

        function renderPersonelList(list, bodyId, type) {
            document.getElementById(bodyId).innerHTML = (list || []).map(p => {
                const id = p.ID || p.id;
                const qrUrl = p.Link_QR || p.link_qr || getQRUrl(p.Nama||p.nama, p.NoHP||p.no_hp);
                return `<tr>
                    <td>${id}</td>
                    <td><img src="${qrUrl}" class="qr-thumb-sm" onclick="window.open('${qrUrl}')"></td>
                    <td><div class="foto-pegawai-sm"><img src="${p.Link_Foto_Profile || p.link_foto_profile || ''}" onerror="this.src='${placeholderImg}'"></div></td>
                    <td style="font-weight:800; text-transform:uppercase;">${p.Nama || p.nama}</td>
                    <td>${p.Jabatan || p.jabatan}</td>
                    <td>${p.Wilayah || p.wilayah}</td>
                    <td><span style="color:${(p.Status||p.status)==='Aktif'?'var(--success)':'#94a3b8'}; font-weight:900;">${p.Status || p.status || 'Aktif'}</span></td>
                    <td><div class="action-cell">
                        <button class="action-icon" onclick="editP('${type}','${id}')"><i data-lucide="edit-3" size="16"></i></button>
                        <button class="action-icon delete" onclick="deleteP('${type}','${id}')"><i data-lucide="trash-2" size="16"></i></button>
                    </div></td>
                </tr>`;
            }).join(''); lucide.createIcons();
        }

        function openPModal(type) { 
            document.getElementById('p-mode').value = type; document.getElementById('p-old-id').value = "";
            document.getElementById('p-id').value = ""; document.getElementById('p-nama').value = "";
            document.getElementById('p-jabatan').value = ""; document.getElementById('p-wilayah').value = "";
            document.getElementById('p-nohp').value = ""; document.getElementById('p-lokasi').value = "";
            document.getElementById('pModalTitle').innerText = type === 'pegawai' ? "Data Pegawai" : "Data Koordinator";
            document.getElementById('qr-display-container').style.display = 'none';
            document.getElementById('p-preview-img').style.display = 'none';
            document.getElementById('p-placeholder').style.display = 'flex';
            document.getElementById('pModal').style.display = 'flex';
        }

        function editP(type, id) {
            const list = type === 'pegawai' ? masterData.pegawai : masterData.korlap;
            const p = list.find(x => String(x.ID || x.id) === String(id));
            if(!p) return;
            document.getElementById('p-mode').value = type; document.getElementById('p-old-id').value = id;
            document.getElementById('p-id').value = p.ID || p.id; document.getElementById('p-nama').value = p.Nama || p.nama;
            document.getElementById('p-jabatan').value = p.Jabatan || p.jabatan; document.getElementById('p-wilayah').value = p.Wilayah || p.wilayah;
            document.getElementById('p-nohp').value = p.NoHP || p.no_hp || "";
            document.getElementById('p-lokasi').value = p.Lokasi_Kerja || p.lokasi_kerja || "";
            document.getElementById('p-status').value = p.Status || p.status || 'Aktif';
            const imgUrl = p.Link_Foto_Profile || p.link_foto_profile;
            if(imgUrl) { document.getElementById('p-preview-img').src = imgUrl; document.getElementById('p-preview-img').style.display = 'block'; document.getElementById('p-placeholder').style.display = 'none'; }
            updateQRRealtime(); document.getElementById('pModal').style.display = 'flex';
        }

        async function savePAction() {
            const type = document.getElementById('p-mode').value;
            const id = document.getElementById('p-id').value;
            const nama = document.getElementById('p-nama').value;
            if(!id || !nama) return alert("ID dan Nama Wajib Diisi!");
            const payload = { token, action: document.getElementById('p-old-id').value ? (type==='pegawai'?'editPegawai':'editKorlap') : (type==='pegawai'?'addPegawai':'addKorlap'), id, nama, jabatan: document.getElementById('p-jabatan').value, wilayah: document.getElementById('p-wilayah').value, noHP: document.getElementById('p-nohp').value, lokasiKerja: document.getElementById('p-lokasi').value, status: document.getElementById('p-status').value, linkQR: getQRUrl(nama, document.getElementById('p-nohp').value), fotoProfile: base64Foto };
            setLoading(true, "Menyimpan..."); await fetch(API, { method: 'POST', body: JSON.stringify(payload) });
            closeModal('pModal'); loadDashboard();
            setLoading(false);
        }

        async function deleteP(type, id) { if(!confirm("Hapus data?")) return; setLoading(true, "Menghapus..."); await fetch(API, { method: 'POST', body: JSON.stringify({ action: type==='pegawai'?'deletePegawai':'deleteKorlap', token, id }) }); loadDashboard(); }

        function openLogModal(mode, nama, id, ts, status, nilai) {
            logMode = mode;
            const dropdown = document.getElementById('manualLogPegawai');
            dropdown.innerHTML = [...(masterData.pegawai||[]), ...(masterData.korlap||[])].map(p => `<option value="${p.ID||p.id}">${p.Nama||p.nama}</option>`).join('');
            if(mode === 'add') {
                document.getElementById('editLogTime').value = new Date().toISOString().slice(0, 16);
            } else {
                dropdown.value = id;
                document.getElementById('editLogIdPeg').value = id; 
                document.getElementById('editLogOriginalTs').value = ts;
                document.getElementById('editLogTime').value = new Date(ts).toISOString().slice(0, 16);
                document.getElementById('editLogStatus').value = status; 
                document.getElementById('editLogNilai').value = nilai;
            }
            document.getElementById('logEditModal').style.display = 'flex';
        }

        async function saveLogAction() {
            let payload = { token };
            const id = document.getElementById('manualLogPegawai').value;
            const p = [...masterData.pegawai, ...masterData.korlap].find(x => String(x.ID||x.id)===String(id));
            if(logMode === 'add') {
                payload.action = 'addLog'; payload.idPegawai = id; payload.nama = p.Nama||p.nama; payload.wilayah = p.Wilayah||p.wilayah;
                payload.timestamp = document.getElementById('editLogTime').value; payload.status = document.getElementById('editLogStatus').value; payload.nilai = document.getElementById('editLogNilai').value;
            } else {
                payload.action = 'editLog'; payload.idPegawai = id; payload.originalTimestamp = document.getElementById('editLogOriginalTs').value;
                payload.newTimestamp = document.getElementById('editLogTime').value; payload.status = document.getElementById('editLogStatus').value; payload.nilai = document.getElementById('editLogNilai').value;
            }
            setLoading(true, "Sinkronisasi..."); await fetch(API, { method: 'POST', body: JSON.stringify(payload) });
            closeModal('logEditModal'); loadLogs();
        }

        async function deleteLog(id, ts) { if(!confirm("Hapus log?")) return; setLoading(true); await fetch(API, { method: 'POST', body: JSON.stringify({ action:'deleteLog', token, id, ts }) }); loadLogs(); }

        async function loadLogs() {
            setLoading(true); const fD = document.getElementById('logDateFilter').value;
            const r = await fetch(API + "?action=getPresensiAdminData"); const d = await r.json();
            const filtered = (d.data || []).filter(l => {
                const t = l.Timestamp||l.timestamp;
                return t ? new Date(t).toISOString().split('T')[0] === fD : false;
            });
            document.getElementById('logsBody').innerHTML = filtered.map(l => {
                const ts = l.Timestamp||l.timestamp;
                const id = l.ID||l.id||l['ID Pegawai'];
                return `<tr><td>${new Date(ts).toLocaleTimeString('id-ID')}</td><td style="font-weight:800; text-transform:uppercase;">${l.Nama||l.nama}</td><td>${l.Status||l.status}</td><td style="color:var(--warning); font-weight:800;">${l.Nilai||l.nilai}</td><td>${l.Wilayah||l.wilayah}</td><td><button class="action-icon" style="border-radius:8px;" onclick="window.open('${l.Foto_Selfie||l.foto_selfie}','_blank')"><i data-lucide="camera" size="14"></i></button></td><td><div class="action-cell"><button class="action-icon" style="color:var(--warning)" onclick="openLogModal('edit','','${id}','${ts}','${l.Status||l.status}','${l.Nilai||l.nilai}')"><i data-lucide="edit-2" size="16"></i></button><button class="action-icon delete" onclick="deleteLog('${id}','${ts}')"><i data-lucide="trash-2" size="16"></i></button></div></td></tr>`
            }).join('') || '<tr><td colspan="7" style="text-align:center; opacity:0.3; padding:50px;">Tidak Ada Aktivitas</td></tr>'; lucide.createIcons(); setLoading(false);
        }

        function renderTools() {
            document.getElementById('toolsBody').innerHTML = (masterData.tools || []).map(t => `<tr><td><div style="width:35px;height:35px;background:${t.Warna||t.warna};display:flex;align-items:center;justify-content:center;border-radius:8px;"><i data-lucide="${t.Icon||t.icon}" size="18"></i></div></td><td style="font-weight:800;">${t.Nama||t.nama}</td><td style="opacity:0.5; font-size:0.75rem;">${t.Deskripsi||t.deskripsi}</td><td><div style="width:20px;height:20px;border-radius:50%;background:${t.Warna||t.warna}"></div></td><td><div class="action-cell"><button class="action-icon" onclick="editTool('${t.Nama||t.nama}')"><i data-lucide="edit-3" size="16"></i></button><button class="action-icon delete" onclick="deleteTool('${t.Nama||t.nama}')"><i data-lucide="trash-2" size="16"></i></button></div></td></tr>`).join(''); lucide.createIcons();
        }
        function openToolModal() { document.getElementById('t-old-name').value = ""; document.getElementById('toolModal').style.display='flex'; }
        function editTool(name) { const t = masterData.tools.find(x => (x.Nama||x.nama)===name); if(!t) return; document.getElementById('t-old-name').value = name; document.getElementById('t-nama').value = t.Nama||t.nama; document.getElementById('t-ikon').value = t.Icon||t.icon; document.getElementById('t-warna').value = t.Warna||t.warna; document.getElementById('t-url').value = t.Link_URL||t.link_url; document.getElementById('t-desc').value = t.Deskripsi||t.deskripsi; document.getElementById('toolModal').style.display='flex'; }
        async function saveTool() { setLoading(true); await fetch(API, { method: 'POST', body: JSON.stringify({ token, action:'saveTool', oldName:document.getElementById('t-old-name').value, nama:document.getElementById('t-nama').value, icon:document.getElementById('t-ikon').value, warna:document.getElementById('t-warna').value, url:document.getElementById('t-url').value, desc:document.getElementById('t-desc').value }) }); closeModal('toolModal'); loadDashboard(); }
        async function deleteTool(name) { if(!confirm("Hapus?")) return; setLoading(true); await fetch(API, { method: 'POST', body: JSON.stringify({ action:'deleteTool', token, name }) }); loadDashboard(); }

        function renderConfig() { document.getElementById('configContainer').innerHTML = Object.keys(masterData.config).map(k => `<div><label>${k.replace(/_/g,' ')}</label><input value="${masterData.config[k]}" id="c-${k}"></div>`).join(''); }
        async function saveConfig() { const newC = {}; Object.keys(masterData.config).forEach(k => newC[k] = document.getElementById('c-'+k).value); setLoading(true); await fetch(API, { method: 'POST', body: JSON.stringify({ action:'updateConfig', token, config: newC }) }); loadDashboard(); }
        
        function handleFile(input) { if (input.files && input.files[0]) { const reader = new FileReader(); reader.onload = (e) => { base64Foto = e.target.result; document.getElementById('p-preview-img').src = base64Foto; document.getElementById('p-preview-img').style.display = 'block'; document.getElementById('p-placeholder').style.display = 'none'; }; reader.readAsDataURL(input.files[0]); } }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; base64Foto = null; }
        function setLoading(s, text) { const overlay = document.getElementById('sendingOverlay'); if(text) document.getElementById('overlayText').innerText = text; overlay.style.display = s ? 'flex' : 'none'; }
    </script>
</body>
</html>
